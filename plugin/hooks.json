{
  "name": "context-manager",
  "version": "0.1.0",
  "description": "Persistent memory for Claude Code sessions",
  "hooks": {
    "SessionStart": {
      "command": "node",
      "args": ["~/.claude/plugins/context-manager/dist/hooks/context-inject.js"],
      "timeout": 5000
    },
    "PostToolUse": {
      "command": "node",
      "args": ["~/.claude/plugins/context-manager/dist/hooks/capture-tool.js"],
      "timeout": 1000
    },
    "Stop": {
      "command": "node",
      "args": ["~/.claude/plugins/context-manager/dist/hooks/session-end.js"],
      "timeout": 5000
    }
  }
}
