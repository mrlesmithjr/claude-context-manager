# Include CLAUDE.md (override global ignore for this project)
!CLAUDE.md

# Include .claude/commands (override global ignore for slash commands)
!.claude/
!.claude/commands/
!.claude/commands/*.md

# Ignore local settings (machine-specific permissions)
.claude/settings.local.json

# Include .claude-plugin directories (marketplace plugin metadata)
!.claude-plugin/
!.claude-plugin/*.json
!plugin/.claude-plugin/
!plugin/.claude-plugin/*.json

# Dependencies
node_modules/
# plugin/node_modules/ is gitignored -- not committed.
# Marketplace installs require server mode (CONTEXT_MANAGER_URL in .env).
# Local SQLite mode: clone repo, run npm install, install with /plugin marketplace add /local/path

# Build output
dist/
# Note: plugin/scripts/ is NOT ignored - built hooks must be committed for GitHub install

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Environment
.env
.env.local

# Test coverage
coverage/

# SQLite database (local dev only)
*.db
*.db-journal
*.db-wal
*.db-shm
