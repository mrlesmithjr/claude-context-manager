# Include CLAUDE.md (override global ignore for this project)
!CLAUDE.md

# Include .claude/commands (override global ignore for slash commands)
!.claude/
!.claude/commands/
!.claude/commands/*.md

# Ignore local settings (machine-specific permissions)
.claude/settings.local.json

# Include .claude-plugin directories (marketplace plugin metadata)
!.claude-plugin/
!.claude-plugin/*.json
!plugin/.claude-plugin/
!plugin/.claude-plugin/*.json

# Dependencies
node_modules/
# EXCEPT plugin's vendored native modules — committed so GitHub installs work.
# These are pruned to runtime-only files (~2MB vs ~12MB full).
# Platform-specific: rebuild with `npm run build:plugin` if switching OS/arch.
!plugin/node_modules/
# Override global gitignore rules that block vendored native build artifacts
!plugin/node_modules/**/build/
!plugin/node_modules/**/build/**

# Build output
dist/
# Note: plugin/scripts/ is NOT ignored - built hooks must be committed for GitHub install

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Environment
.env
.env.local

# Test coverage
coverage/

# SQLite database (local dev only)
*.db
*.db-journal
*.db-wal
*.db-shm
