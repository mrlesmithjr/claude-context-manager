<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mrlesmithjr.context-manager</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{NODE_PATH}}</string>
        <string>{{PROJECT_ROOT}}/test/e2e/start-server.mjs</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>CONTEXT_MANAGER_DB</key>
        <string>{{HOME}}/.claude-context/context.db</string>
        <key>CONTEXT_MANAGER_TOKEN</key>
        <string>{{TOKEN}}</string>
        <key>CONTEXT_MANAGER_PORT</key>
        <string>4000</string>
        <key>CONTEXT_MANAGER_HOST</key>
        <string>127.0.0.1</string>
        <key>LOG_LEVEL</key>
        <string>warn</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>{{HOME}}/.claude-context/server.log</string>

    <key>StandardErrorPath</key>
    <string>{{HOME}}/.claude-context/server-error.log</string>

    <key>WorkingDirectory</key>
    <string>{{PROJECT_ROOT}}</string>
</dict>
</plist>
