{
  "name": "claude-context-manager",
  "version": "0.8.33",
  "description": "Persistent memory for Claude Code sessions",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "context-manager": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:src && npm run build:hooks && npm run build:cli && npm run build:web",
    "build:all": "npm run build",
    "build:src": "tsc",
    "build:hooks": "node scripts/build-hooks.js",
    "build:cli": "esbuild cli/index.ts --bundle --outfile=dist/cli.js --platform=node --target=node18 --format=esm --external:better-sqlite3 --external:sqlite-vec --external:onnxruntime-node --banner:js=\"#!/usr/bin/env node\"",
    "build:web": "esbuild web/server/index.ts --bundle --outfile=dist/web/server.js --platform=node --target=node18 --format=esm --external:better-sqlite3 --packages=external",
    "build:plugin": "npm run typecheck && npm run test:docker && npm run build && node scripts/install.js",
    "plugin:uninstall": "node scripts/uninstall.js",
    "plugin:uninstall:all": "node scripts/uninstall.js --remove-data",
    "clean": "rm -rf dist plugin/scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:docker": "docker build -f Dockerfile.test -t context-manager-test . && docker run --rm context-manager-test",
    "cli": "node dist/cli.js",
    "import": "npx tsx scripts/import-transcripts.ts",
    "web": "node dist/web/server.js",
    "web:dev": "npx tsx watch web/server/index.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "memory",
    "context",
    "plugin"
  ],
  "author": "Larry Smith Jr. <mrlesmithjr@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.6.2",
    "sqlite-vec": "^0.1.6"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.19.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
